# ============================================================
# SkillHub — Variables d'environnement (template)
# ============================================================
# Copier ce fichier en `.env` puis remplir les valeurs réelles.
# Le fichier `.env` n'est JAMAIS commité (voir .gitignore).
# ============================================================


# ─── MySQL ───────────────────────────────────────────────────
# Mot de passe root de la base MySQL (à régénérer en production).
MYSQL_ROOT_PASSWORD=root
# Nom de la base principale créée au démarrage du container.
MYSQL_DATABASE=skillhub


# ─── Backend Laravel (skillhub-back) ─────────────────────────
APP_ENV=local
# Clé d'app Laravel : `php artisan key:generate` pour la générer.
APP_KEY=base64:GENEREZ_UNE_CLE_BASE64_DE_32_OCTETS
APP_DEBUG=true
APP_URL=http://localhost:8001

# Connexion DB Laravel (host = nom du service docker-compose).
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=skillhub
DB_USERNAME=root
DB_PASSWORD=root

# JWT pour l'authentification API (tymon/jwt-auth).
# Doit faire au moins 32 caractères. Générer avec :
# `php artisan jwt:secret --force`
JWT_SECRET=GENEREZ_UN_SECRET_JWT_DE_AU_MOINS_32_CARACTERES

# MongoDB pour les logs d'activité.
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=skillhub_messages
MONGO_USERNAME=
MONGO_PASSWORD=

# Mail (en dev : log dans storage/logs/laravel.log).
MAIL_MAILER=log

# Coverage Xdebug en dev (mettre `off` en production pour la perf).
XDEBUG_MODE=coverage


# ─── Auth Service Spring Boot (springboot) ───────────────────
# URL de connexion JDBC (port 3306 = réseau interne Docker).
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/tp5_auth_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# Clé maître AES pour le chiffrement réversible des mots de passe.
# CRITIQUE — protéger comme un secret de niveau bancaire.
APP_SECURITY_SMK=GENEREZ_UNE_CLE_AES_DE_32_OCTETS

# JWT Spring Boot (DOIT FAIRE >= 32 CARACTÈRES POUR HS256).
JWT_SECRET_SPRING=GENEREZ_UN_SECRET_JWT_LONG_DE_AU_MOINS_32_CARACTERES

# SMTP (laisser vide en dev si pas de mails à envoyer).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=


# ─── CI/CD (à configurer dans GitHub Secrets, PAS en .env) ───
# DOCKER_USERNAME=...
# DOCKER_PASSWORD=...
# SONAR_TOKEN=...
