# Normalisation auto des fins de ligne — text=auto = Git détecte
# si le fichier est texte et applique LF en interne, CRLF en checkout
# sur Windows si l'utilisateur le veut.
* text=auto eol=lf

# Fichiers Docker / shell : OBLIGATOIREMENT en LF (sinon container Linux casse)
Dockerfile     text eol=lf
*.sh           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
.dockerignore  text eol=lf
.env.example   text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
mvnw           text eol=lf

# Fichiers de configuration : LF
*.properties   text eol=lf
*.json         text eol=lf
*.xml          text eol=lf
*.toml         text eol=lf

# Code source : LF
*.js           text eol=lf
*.jsx          text eol=lf
*.ts           text eol=lf
*.tsx          text eol=lf
*.php          text eol=lf
*.java         text eol=lf
*.py           text eol=lf
*.html         text eol=lf
*.css          text eol=lf
*.scss         text eol=lf
*.md           text eol=lf

# Fichiers binaires : pas de conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.jar   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary

# Windows .bat : CRLF (sinon ne s'exécute pas)
*.bat   text eol=crlf
*.cmd   text eol=crlf
mvnw.cmd text eol=crlf
